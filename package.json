{
  "name": "jntu-site",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "JNTUStack: custom Node.js site generator + Express server, deployed on Hostinger Node.js hosting.",
  "scripts": {
    "build": "node scripts/build.js && node scripts/build-search-index.js",
    "start": "node server.js",
    "dev": "npm run build && node server.js",
    "audit:site": "node scripts/audit-site.js",
    "test:content-store": "node scripts/check-content-store.js",
    "test:parsers": "node scripts/test-parsers.js",
    "test:admin-ui": "node scripts/test-admin-ui.js",
    "db:import-json": "node scripts/import-json-to-db.js",
    "db:export-json": "node scripts/export-db-to-json.js",
    "db:parity": "node scripts/check-db-parity.js",
    "db:migrate": "node scripts/db.js migrate",
    "db:status": "node scripts/db.js status",
    "test:retrieve": "node scripts/retrieve-test.js",
    "postinstall": "npm run build"
  },
  "engines": {
    "node": "24.x"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2",
    "mysql2": "^3.15.3",
    "php-serialize": "^5.1.3",
    "unpdf": "^1.6.2"
  }
}

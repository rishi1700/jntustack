{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://jntukmaterials.com/schema/content-model.json",
  "title": "JNTUKMaterials Content Data Model",
  "description": "Single source of truth for the rebuilt site. Every regulation hub, branch hub, semester page, and subject page is rendered from a record validated against this schema. Nothing is generated free-form from a prompt without a backing record here.",
  "definitions": {
    "Regulation": {
      "type": "object",
      "required": ["code", "full_name", "status", "effective_from"],
      "properties": {
        "code": { "type": "string", "examples": ["R16", "R19", "R20", "R23", "R25"] },
        "full_name": { "type": "string" },
        "effective_from": {
          "type": "string",
          "description": "Academic year new admits started under this regulation, e.g. '2023-24'"
        },
        "status": {
          "type": "string",
          "enum": ["active", "legacy", "deprecated", "unconfirmed"],
          "description": "active = current admits use this; legacy = superseded but supply/backlog students still search it; deprecated = effectively dead traffic; unconfirmed = referenced but not yet verified as real/scoped"
        },
        "supersedes": { "type": ["string", "null"], "description": "Code of the regulation this one replaced" },
        "branch_groups": {
          "type": "object",
          "description": "Some regulations stagger rollout by branch bucket (e.g. R23's Group-A / Group-B)",
          "additionalProperties": { "type": "array", "items": { "type": "string" } }
        },
        "evaluation_scheme": { "type": "string" },
        "honors_minor_rules": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"], "format": "uri" },
        "last_verified": { "type": "string", "format": "date" },
        "notes": { "type": ["string", "null"] }
      }
    },
    "Specialization": {
      "type": "object",
      "required": ["code", "name"],
      "properties": {
        "code": { "type": "string", "examples": ["CSE", "CSE-AIML", "CSE-AIDS", "CSE-DS", "CSE-CS", "CSE-IOT", "CSD"] },
        "name": { "type": "string" }
      }
    },
    "Branch": {
      "type": "object",
      "required": ["code", "name"],
      "properties": {
        "code": { "type": "string", "examples": ["CSE", "IT", "ECE", "EEE", "CE", "MECH"] },
        "name": { "type": "string" },
        "group": { "type": ["string", "null"], "description": "Branch bucket under the active regulation, if applicable" },
        "specializations": {
          "type": "array",
          "items": { "$ref": "#/definitions/Specialization" },
          "description": "Distinct syllabus variants under this branch in this regulation (R23 split CSE into several, each with its own syllabus PDF)"
        }
      }
    },
    "Unit": {
      "type": "object",
      "required": ["number", "title"],
      "properties": {
        "number": { "type": "integer" },
        "title": { "type": "string" },
        "topics": { "type": "array", "items": { "type": "string" } }
      }
    },
    "Resources": {
      "type": "object",
      "properties": {
        "lecture_notes_pdf": { "type": ["string", "null"], "format": "uri" },
        "previous_question_papers_pdf": { "type": ["string", "null"], "format": "uri" },
        "lab_manual_pdf": { "type": ["string", "null"], "format": "uri" }
      }
    },
    "SEO": {
      "type": "object",
      "required": ["slug", "title", "meta_description"],
      "properties": {
        "slug": { "type": "string" },
        "title": { "type": "string", "maxLength": 60 },
        "meta_description": { "type": "string", "maxLength": 160 }
      }
    },
    "Source": {
      "type": "object",
      "required": ["status"],
      "properties": {
        "origin_url": { "type": ["string", "null"], "format": "uri" },
        "retrieved_date": { "type": ["string", "null"], "format": "date" },
        "status": {
          "type": "string",
          "enum": ["verified", "needs_verification", "placeholder"],
          "description": "verified = checked against an official JNTUK/UCEN/affiliated-college source; needs_verification = structurally present but not yet checked against a primary source; placeholder = scaffolding only, must not be published as-is"
        },
        "college_source_note": {
          "type": ["string", "null"],
          "description": "Optional short, single-sentence, student-facing caveat about the source itself (e.g. autonomous-college sourcing). Rendered on the page in a disclaimer box; only populate when a reader genuinely needs to know. Distinct from the internal maintainer-facing notes field on the record."
        }
      }
    },
    "College": {
      "type": "object",
      "required": ["name", "affiliated_to", "location", "type", "branches_offered", "source"],
      "properties": {
        "name": { "type": "string" },
        "short_code": { "type": ["string", "null"], "description": "Official affiliation code, if known" },
        "affiliated_to": { "type": "string", "enum": ["JNTUK", "JNTUH", "JNTUA", "JNTUGV"] },
        "location": {
          "type": "object",
          "properties": { "city": { "type": "string" }, "district": { "type": "string" }, "state": { "type": "string" } }
        },
        "type": { "type": "string", "enum": ["Government", "Private", "Autonomous-Private", "Constituent"], "description": "Constituent = a university's own college (e.g. UCEK Kakinada), not a third-party affiliate" },
        "branches_offered": { "type": "array", "items": { "type": "string" }, "description": "Branch.code values" },
        "official_website": { "type": ["string", "null"], "format": "uri" },
        "nirf_rank": { "type": ["integer", "null"], "description": "Only ever populated from an actual published NIRF list -- never estimated or guessed" },
        "source": { "$ref": "#/definitions/Source" }
      }
    },
    "BranchProfile": {
      "type": "object",
      "required": ["branch", "tagline", "core_focus", "suits_students_who", "career_paths", "source"],
      "properties": {
        "branch": { "type": "string", "description": "Branch.code" },
        "tagline": { "type": "string", "maxLength": 90, "description": "One honest sentence capturing what this branch actually is, no marketing spin" },
        "core_focus": {
          "type": "array",
          "items": { "type": "string" },
          "description": "The handful of subject areas that actually define the 4 years -- not the full subject list, the load-bearing ones"
        },
        "suits_students_who": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Honest fit signals, phrased as things a student can self-assess, not flattering generalities"
        },
        "less_good_fit_if": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Equally honest signals this branch probably isn't the right call -- omitting this list is how guidance becomes marketing"
        },
        "career_paths": { "type": "array", "items": { "type": "string" } },
        "further_study_paths": { "type": "array", "items": { "type": "string" }, "description": "GATE/PSU/MS-abroad/MBA type routes, qualitative only" },
        "related_branches": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Branch.code values worth comparing against before deciding -- e.g. CSE should always surface IT and the R23 CSE specializations alongside it"
        },
        "data_disclaimer": {
          "type": "string",
          "description": "Required, shown on-page: clarifies that no placement/salary statistics are claimed unless explicitly sourced"
        },
        "source": { "$ref": "#/definitions/Source" }
      }
    },
    "Subject": {
      "type": "object",
      "required": ["id", "regulation", "branch", "year", "semester", "name", "category", "type", "seo", "source"],
      "properties": {
        "id": {
          "type": "string",
          "description": "Stable unique slug, e.g. r23-cse-3-1-data-warehousing-and-data-mining"
        },
        "regulation": { "type": "string", "description": "Regulation.code" },
        "branch": { "type": "string", "description": "Branch.code" },
        "specialization": { "type": ["string", "null"], "description": "Specialization.code, null if the branch has no variants" },
        "year": { "type": "integer", "minimum": 1, "maximum": 4 },
        "semester": { "type": "integer", "enum": [1, 2] },
        "year_sem_label": { "type": "string", "examples": ["1-1", "3-2"] },
        "subject_code": { "type": ["string", "null"] },
        "name": { "type": "string" },
        "category": {
          "type": "string",
          "enum": [
            "BasicScience", "EngineeringScience", "ProfessionalCore", "ProfessionalElective",
            "OpenElective", "HSMC", "SkillEnhancement", "AbilityEnhancement",
            "MandatoryNonCredit", "Honors", "Minor", "Project", "Internship", "Lab"
          ]
        },
        "credits": {
          "type": ["object", "null"],
          "properties": {
            "L": { "type": "number" }, "T": { "type": "number" },
            "P": { "type": "number" }, "C": { "type": "number" }
          }
        },
        "type": { "type": "string", "enum": ["theory", "lab", "theory_cum_lab", "project", "internship", "seminar"] },
        "units": { "type": "array", "items": { "$ref": "#/definitions/Unit" } },
        "course_outcomes": { "type": "array", "items": { "type": "string" } },
        "resources": { "$ref": "#/definitions/Resources" },
        "seo": { "$ref": "#/definitions/SEO" },
        "legacy_equivalent_id": {
          "type": ["string", "null"],
          "description": "id of the equivalent subject under an older regulation already live on the site -- cross-link instead of orphaning that page"
        },
        "source": { "$ref": "#/definitions/Source" },
        "notes": { "type": ["string", "null"] }
      }
    }
  },
  "type": "object",
  "required": ["regulations", "branches", "subjects"],
  "properties": {
    "regulations": { "type": "array", "items": { "$ref": "#/definitions/Regulation" } },
    "branches": { "type": "array", "items": { "$ref": "#/definitions/Branch" } },
    "subjects": { "type": "array", "items": { "$ref": "#/definitions/Subject" } },
    "branch_profiles": { "type": "array", "items": { "$ref": "#/definitions/BranchProfile" } },
    "colleges": { "type": "array", "items": { "$ref": "#/definitions/College" } }
  }
}
